# NexPlay Environment Variables
# Copy this to .env and fill in your values

# Get from vast.ai → Account → API Key
VAST_API_KEY=paste_your_vast_api_key_here

# MTN MoMo API (get from developer.mtn.com after registering)
MTN_SUBSCRIPTION_KEY=paste_here
MTN_API_USER=paste_here
MTN_API_KEY=paste_here

# Airtel Money API (get from developers.airtel.africa)
AIRTEL_CLIENT_ID=paste_here
AIRTEL_CLIENT_SECRET=paste_here

# Make up any random string — keeps your app secure
SECRET_KEY=nexplay-super-secret-key-change-this-123

# Admin password — only you know this
ADMIN_KEY=nexplay-admin-password-change-this

# Port (Render sets this automatically)
PORT=5000
